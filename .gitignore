# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
wheels/
*.egg

# Virtual environments
.venv/

# Environment
.env

# Data — raw and processed are git-ignored; results and grounding are tracked
data/raw/
data/processed/
data/transcripts/

# Non-canonical shakedown runs per docs/SHAKEDOWN_PROTOCOL.md.
# Shakedown data is diagnostic-only, must never be committed alongside code,
# and must be machine-prevented from being confused with canonical data in
# data/raw/. Path segregation is the primary non-canonical labeling mechanism
# (see SHAKEDOWN_PROTOCOL.md §2).
data/shakedown/

# One-off diagnostic probes (e.g., reproducibility checks against the live
# API). The probe script under scripts/ is committed; the captured output
# is treated like shakedown data — local-only, reproducible by re-running
# the script.
data/probes/

# Open data bundle build artifacts — produced by scripts/build_open_bundle.py
# and scripts/build_db.py from the canonical data sources. Not suitable for
# git. The .gitkeep preserves the directory in the tree. data/open_bundle/README.md
# IS tracked (source file committed as part of T6).
data/open_bundle/*.sqlite
data/open_bundle/*.tar.gz

# Note: data/cost_reports/*.txt is NOT ignored (git-tracked per ARCHITECTURE.md §6.2)

# Dashboard build artifacts
apps/dashboard/dist/
apps/dashboard/.vite/
node_modules/

# Dashboard data build artifacts — generated by scripts/publish.py from
# data/results/. These files are computed artifacts, not source; regenerated
# on every build. The public/_headers file is tracked (it's source config).
apps/dashboard/public/data/

# Reference materials (PDFs, local copies of papers — not suitable for git)
docs/references/

# Host-local operator notes (VPS-specific; intentionally never committed)
HARDWARE.md

# Local screenshots used as Claude-Code debugging aids — not canonical docs
docs/screenshots/

# Social publishing pipeline runtime directories (queue and state are
# operator-local runtime artifacts; only out/social/README.md is tracked)
out/social/queue/
out/social/state/

# OS
.DS_Store
Thumbs.db

# Logs (content is never tracked; logs/.gitkeep keeps the directory in git)
logs/*
!logs/.gitkeep

# IDE
.idea/
*.swp
*.swo
*~
".claude/scheduled_tasks.lock" 
".claude/settings.local.json" 
.playwright-mcp/
