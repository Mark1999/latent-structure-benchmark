# LSB environment variables — copy to .env and fill in real values.
# .env is git-ignored; this file is tracked.

# API keys for model collection (ARCHITECTURE.md §4.1)
# Direct API keys — preferred over OpenRouter where available
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
XAI_API_KEY=xai-...
# DEEPSEEK_API_KEY — not used; DeepSeek routed via OpenRouter (security)
# MISTRAL_API_KEY — not used; no thinking traces, routed via OpenRouter
# Aggregator keys — used for models without direct API access
OPENROUTER_API_KEY=sk-or-...
HUGGINGFACE_API_KEY=hf_...

# Slack webhook URLs for operational channels (ARCHITECTURE.md §5.4)
LSB_ALERTS_WEBHOOK_URL=https://hooks.slack.com/services/...
LSB_CDA_SME_WEBHOOK_URL=https://hooks.slack.com/services/...
LSB_UI_UX_WEBHOOK_URL=https://hooks.slack.com/services/...

# Phase 7 social pipeline — Bluesky live publishing (Phase 7 T6/T6b)
# Bluesky has live publishing support in v1. X and LinkedIn are draft-only.
# BLUESKY_HANDLE is used by both the admin console publish route (T6b) and the
# publisher module (T6) to identify the posting account. The admin console
# displays it verbatim in the publish confirmation page per CDA SME §5.9:
# "This will post to Bluesky as @{handle}."
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-bluesky-app-password

# X (Twitter) and LinkedIn are draft-only in Phase 7 v1:
# - X: requires paid API tier (~$100/mo floor); ship as draft-export-only.
# - LinkedIn: requires partner-program approval; ship as draft-export-only.
# These env vars are placeholders for future use when those platforms are enabled.
# X_API_KEY=...
# X_API_SECRET=...
# X_ACCESS_TOKEN=...
# X_ACCESS_TOKEN_SECRET=...
# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...

# Gmail SMTP for daily digest emails (Phase 7 T6a).
# Generate a Gmail app password at https://myaccount.google.com/apppasswords
# and store the 16-character password here (no spaces).
LSB_SMTP_USERNAME=your-gmail-username@gmail.com
LSB_SMTP_PASSWORD=your-gmail-app-password
LSB_DIGEST_RECIPIENT=your-recipient@example.com

# backblaze credentials (for backups and open bundle publishing)
B2_KEY_ID=...
B2_APPLICATION_KEY=...
B2_BUCKET_NAME=lsb-backups
