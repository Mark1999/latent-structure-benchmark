# LSB environment variables — copy to .env and fill in real values.
# .env is git-ignored; this file is tracked.

# API keys for model collection (ARCHITECTURE.md §4.1)
# Direct API keys — preferred over OpenRouter where available
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
XAI_API_KEY=xai-...
# DEEPSEEK_API_KEY — not used; DeepSeek routed via OpenRouter (security)
# MISTRAL_API_KEY — not used; no thinking traces, routed via OpenRouter
# Aggregator keys — used for models without direct API access
OPENROUTER_API_KEY=sk-or-...
HUGGINGFACE_API_KEY=hf_...

# Slack webhook URLs for operational channels (ARCHITECTURE.md §5.4)
LSB_ALERTS_WEBHOOK_URL=https://hooks.slack.com/services/...
LSB_CDA_SME_WEBHOOK_URL=https://hooks.slack.com/services/...
LSB_UI_UX_WEBHOOK_URL=https://hooks.slack.com/services/...

# backblaze credentials (for backups and open bundle publishing)
B2_KEY_ID=...
B2_APPLICATION_KEY=...
B2_BUCKET_NAME=lsb-backups
